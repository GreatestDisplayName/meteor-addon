{
  "schemaVersion": 1,
  "id": "meteor-addon",
  "version": "${version}",
  "name": "Meteor Addon",
  "description": "A comprehensive addon for Meteor Client with custom modules and utilities.",
  "authors": [
    "GreatestDisplayName"
  ],
  "contact": {
    "sources": "https://github.com/GreatestDisplayName/meteor-addon"
  },
  "icon": "assets/template/icon.png",
  "environment": "client",
  "entrypoints": {
    "meteor": [
      "com.meteoraddon.addon.AddonTemplate"
    ]
  },
  "mixins": [
    "meteor-addon.mixins.json"
  ],
  "custom": {
    "meteor-client:color": "225,25,25",
    "modmenu": {
      "parent": {
        "id": "meteor-client"
      }
    }
  },
  "depends": {
    "java": ">=21",
    "minecraft": ["${mc_version}"],
    "meteor-client": "*"
  }
}
